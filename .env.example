# Lake & Pine — environment variable manifest (NAMES ONLY, NO VALUES)
#
# Source of truth for VALUES is Doppler once a lakeandpine Doppler project exists
# (cross-portfolio standard). Until then: real values live in apps/web/.env.local,
# which is git-ignored. Never paste real secrets here or commit a real .env.
#
# CROSS-APP PROVIDER LOCK (matches E&E / BidSpace / Sweepza, 2026-06-04):
# Auth = Clerk (NOT Supabase Auth), Maps = Mapbox, Data = Supabase (Postgres/storage),
# Payments = Stripe, Email = Resend, Analytics = PostHog, Errors = Sentry, Hosting = Vercel.

# --- Database (REQUIRED) ---
# All data access is server-side over this connection. Dev: local Postgres container
# (docker: lp-postgres, port 5442). Production: the dedicated Supabase project's
# transaction-pooler connection string. Production currently uses the dedicated
# `lakeandpine_app` credential; an owner connection is also safe only because every
# physical app connection immediately selects the reviewed non-owner role below.
DATABASE_URL=
# Keep this exact role in every deployed environment. /api/health fails closed if
# the connection does not report it or the operations migration is unavailable.
DATABASE_RUNTIME_ROLE=lakeandpine_app

# --- Supabase (project keys — used for storage/realtime once the project exists) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (AUTH — cross-app standard; customer accounts + staff role) ---
# TODO(jackson): create the "lakeandpine" Clerk application and fill these.
# The app runs public surfaces without them; /dashboard requires them in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Stripe (payments; test mode until go-live) ---
# TODO(jackson): create products/prices in Stripe and fill per-env. requireEnv throws
# at checkout time if a needed price id is unset (never silently mispriced).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring plan prices (per-clean anchors billed per visit; see services/stripe).
STRIPE_PRICE_PLAN_WEEKLY=
STRIPE_PRICE_PLAN_BIWEEKLY=
STRIPE_PRICE_PLAN_MONTHLY=
STRIPE_PRICE_ONE_TIME=
# Separate hard gate. Keep false until live-money activation is explicitly approved
# and checkout/webhook/refund smoke tests pass in the intended Stripe mode.
PAYMENTS_ENABLED=false

# --- Resend (request confirmations, operations alerts, and service follow-up) ---
RESEND_API_KEY=
# Verified sender identity. Required before intake can be enabled.
RESEND_FROM=
RESEND_FROM_EMAIL=
# Verified reply/operations routing. These should be independent from a
# no-reply sender so customers can reach a monitored inbox.
RESEND_REPLY_TO=
SUPPORT_EMAIL=

# --- PostHog (product analytics / conversion instrumentation) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Sentry (runtime monitoring; DSN read server-side AND client-side) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Mapbox (MAPS — cross-app standard; service-area pages) ---
# Without a token the area map renders the branded SVG fallback.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Vercel (hosting) ---
# Preview/development URL override. Production deliberately canonicalizes to
# https://lakeandpinecleaning.com even if a stale Vercel alias remains configured.
NEXT_PUBLIC_APP_URL=

# --- Business identity (non-secret, overridable) ---
# Public phone/email shown across the site. Leave both empty until ownership and
# delivery are verified; the app hides direct-contact CTAs when they are unset.
# Phone: use E.164 with a leading + and country code (for example +12087654321).
# Ten-digit US/Canada and eleven-digit 1-prefixed numbers are also accepted.
# Other national-format numbers are rejected because their country is ambiguous.
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=

# --- Dev-only ---
# When Clerk keys are absent outside production, /dashboard can preview as this
# seeded dev customer email (never active in production builds).
DEV_PREVIEW_CUSTOMER_EMAIL=
# Non-production operator workspace. Must point to a seeded staff customer;
# preview mode is restricted to rows marked is_dev_seed.
DEV_PREVIEW_OPERATOR_EMAIL=
# Non-production cleaner workspace. Must point to an is_dev_seed cleaner row.
DEV_PREVIEW_CLEANER_EMAIL=
# Explicit approval gate for storing public booking/lead submissions. Leave false
# until the founder approves real customer-data collection.
REQUEST_INTAKE_ENABLED=false
# Separate public scheduling gate. Keep false until the scheduling migrations,
# active territory/service policies, synthetic browser proof, monitored ownership,
# and an explicit activation decision are complete.
CUSTOMER_SCHEDULING_ENABLED=false
# Separate recruiting gate. Cleaner applications collect no identity documents or
# screening data; keep disabled until a monitored hiring owner is assigned.
CLEANER_APPLICATIONS_ENABLED=false
# Required before enabling public intake. Use an independent random value of at
# least 32 characters to HMAC request fingerprints; raw IP addresses are never stored.
REQUEST_FINGERPRINT_SECRET=
# Independent 32+ character HMAC secret for opaque slot identifiers and private
# guest-management links. Do not reuse a provider credential.
CUSTOMER_SCHEDULING_SECRET=
# Optional independent HMAC secret for customer booking references. When omitted,
# REQUEST_FINGERPRINT_SECRET is used. Prefer a separate 32+ character value in production.
BOOKING_REFERENCE_SECRET=
# Non-production only. Set the same random 32+ character value in the app server
# and ops:smoke-runtime process. Never configure this in Production.
RUNTIME_SMOKE_TOKEN=

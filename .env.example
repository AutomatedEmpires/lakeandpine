# Lake & Pine — environment variable manifest (NAMES ONLY, NO VALUES)
#
# Source of truth for VALUES is Doppler once a lakeandpine Doppler project exists
# (cross-portfolio standard). Until then: real values live in apps/web/.env.local,
# which is git-ignored. Never paste real secrets here or commit a real .env.
#
# CROSS-APP PROVIDER LOCK (matches E&E / BidSpace / Sweepza, 2026-06-04):
# Auth = Clerk (NOT Supabase Auth), Maps = Mapbox, Data = Supabase (Postgres/storage),
# Payments = Stripe, Email = Resend, Analytics = PostHog, Errors = Sentry, Hosting = Vercel.

# --- Database (REQUIRED) ---
# All data access is server-side over this connection. Dev: local Postgres container
# (docker: lp-postgres, port 5442). Production: the dedicated Supabase project's
# connection string (Settings -> Database -> Connection string, transaction pooler).
# NOTE 2026-07-06: the AutomatedEmpires Supabase org is at its 2-free-project limit
# (sweepza + explore&earn). To go live: upgrade the org or free a slot, create the
# "lakeandpine" project, run supabase/migrations/*.sql against it, and point this URL at it.
DATABASE_URL=

# --- Supabase (project keys — used for storage/realtime once the project exists) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (AUTH — cross-app standard; customer accounts + staff role) ---
# TODO(jackson): create the "lakeandpine" Clerk application and fill these.
# The app runs public surfaces without them; /dashboard requires them in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Stripe (payments; test mode until go-live) ---
# TODO(jackson): create products/prices in Stripe and fill per-env. requireEnv throws
# at checkout time if a needed price id is unset (never silently mispriced).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring plan prices (per-clean anchors billed per visit; see services/stripe).
STRIPE_PRICE_PLAN_WEEKLY=
STRIPE_PRICE_PLAN_BIWEEKLY=
STRIPE_PRICE_PLAN_MONTHLY=
STRIPE_PRICE_ONE_TIME=

# --- Resend (transactional email: booking confirmations, quote follow-ups, review requests) ---
RESEND_API_KEY=
# Optional From override (defaults to "Lake & Pine <hello@lakeandpinecleaning.com>").
RESEND_FROM_EMAIL=

# --- PostHog (product analytics / conversion instrumentation) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Sentry (runtime monitoring; DSN read server-side AND client-side) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Mapbox (MAPS — cross-app standard; service-area pages) ---
# Without a token the area map renders the branded SVG fallback.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Vercel (hosting) ---
# Public canonical URL — metadataBase, sitemap, OG tags. Non-secret, set per-environment.
NEXT_PUBLIC_APP_URL=

# --- Business identity (non-secret, overridable) ---
# Public phone/email shown across the site. Leave phone empty until a real
# business line exists; the app hides phone CTAs when this is unset.
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=

# --- Dev-only ---
# When Clerk keys are absent outside production, /dashboard can preview as this
# seeded dev customer email (never active in production builds).
DEV_PREVIEW_CUSTOMER_EMAIL=
# Non-production only. Set the same random 32+ character value in the app server
# and ops:smoke-runtime process. Never configure this in Production.
RUNTIME_SMOKE_TOKEN=
